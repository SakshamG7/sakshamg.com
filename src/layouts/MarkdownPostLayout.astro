---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
const pageDescription = frontmatter.description || `Read ${frontmatter.title} by Saksham Goel.`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
        <meta name="description" content={pageDescription} />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <Header />
    <main class="animate">
      <article class="post-content">
        <div class="post-header">
            <h1>{frontmatter.title}</h1>
            <div class="meta">
                <span class="date">{frontmatter.pubDate.toString().slice(0,10)}</span>
                <span class="author">by {frontmatter.author}</span>
            </div>
            {frontmatter.image && 
                <img src={frontmatter.image.url} width="100%" alt={frontmatter.image.alt} class="hero-image" />
            }
             <div class="tags">
                {frontmatter.tags.map((tag) => (
                <span class="tag">{tag}</span>
                ))}
            </div>
        </div>
        
        <div class="markdown-body">
            <slot />
        </div>
      </article>
    </main>
    <Footer />
    
    <style>
      .post-content {
          max-width: 700px;
          margin: 0 auto;
      }
      .post-header {
          margin-bottom: 3rem;
          border-bottom: 1px solid var(--border-color);
          padding-bottom: 2rem;
      }
      .meta {
          display: flex;
          gap: 1rem;
          color: #a8a29e;
          font-family: var(--font-mono);
          font-size: 0.9rem;
          margin-bottom: 1.5rem;
      }
      .hero-image {
          border-radius: 12px;
          margin-bottom: 1.5rem;
          border: 1px solid var(--border-color);
      }
      .tags {
          display: flex;
          gap: 0.5rem;
          flex-wrap: wrap;
      }
      .tag {
          font-family: var(--font-mono);
          font-size: 0.8rem;
          color: var(--accent-color);
          background: rgba(249, 115, 22, 0.1);
          padding: 0.2rem 0.6rem;
          border-radius: 4px;
      }
      
      /* Markdown Content Styles */
      .markdown-body {
          line-height: 1.8;
          font-size: 1.1rem;
      }
      .markdown-body :global(h2) {
          margin-top: 3rem;
          margin-bottom: 1rem;
          font-size: 1.8rem;
          color: white;
      }
      .markdown-body :global(p) {
          margin-bottom: 1.5rem;
          color: #d6d3d1;
      }
      .markdown-body :global(ul), .markdown-body :global(ol) {
          margin-bottom: 1.5rem;
          padding-left: 1.5rem;
          color: #d6d3d1;
      }
      .markdown-body :global(li) {
          margin-bottom: 0.5rem;
      }
      .markdown-body :global(blockquote) {
          border-left: 4px solid var(--accent-color);
          margin: 1.5rem 0;
          padding-left: 1rem;
          color: #a8a29e;
          font-style: italic;
      }
      .markdown-body :global(img) {
          max-width: 100%;
          border-radius: 8px;
          margin: 1.5rem 0;
      }
       .markdown-body :global(pre) {
          padding: 1.5rem;
          border-radius: 8px;
          border: 1px solid var(--border-color);
          margin: 1.5rem 0;
       }
    </style>
  </body>
</html>
