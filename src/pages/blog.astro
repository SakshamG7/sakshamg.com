---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface MarkdownPost {
  frontmatter: {
    title: string;
    pubDate: string;
    description: string;
    tags: string[];
  };
  url: string;
  file: string;
}

const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true })) as MarkdownPost[];
const pageTitle = "Blog | Saksham Goel";
const pageDescription = "Read Saksham Goel's blog posts on AI, computer science, engineering ideas, and lessons from building real projects.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={pageDescription} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<Header />
		<main class="animate">
			<h1>Mental <span class="text-gradient">Models</span> & Tech</h1>
			<p class="intro">Sharing insights on Artificial Intelligence, Computer Science, and my technical journey at RIT.</p>
			
			<div class="blog-list">
				{allPosts.length > 0 ? (
					allPosts.sort((a, b) => Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate)).map((post, index) => (
						<a href={post.url} class={`blog-card stagger-${(index % 4) + 1}`}>
							<div class="blog-meta">
								<span class="date">{post.frontmatter.pubDate.toString().slice(0,10)}</span>
								<div class="blog-tags">
									{post.frontmatter.tags?.slice(0, 2).map(tag => <span class="mini-tag">{tag}</span>)}
								</div>
							</div>
							<h3>{post.frontmatter.title}</h3>
							<p>{post.frontmatter.description}</p>
							<span class="read-more">Read Entry <span class="arrow">&rarr;</span></span>
						</a>
					))
				) : (
					<p class="no-posts">Check back soon for new posts!</p>
				)}
			</div>
		</main>

		<Footer />

		<style>
			.intro {
				font-size: 1.25rem;
				color: #a8a29e;
				margin-bottom: 4rem;
				max-width: 600px;
			}
			.blog-list {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
				gap: 2rem;
			}
			.blog-card {
				background: var(--card-bg);
				border: 1px solid var(--border-color);
				padding: 2rem;
				border-radius: 20px;
				transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
				display: flex;
				flex-direction: column;
				text-decoration: none;
				color: inherit;
			}
			.blog-card:hover {
				border-color: var(--accent-color);
				transform: translateY(-5px);
				box-shadow: 0 10px 30px -10px rgba(249, 115, 22, 0.15);
			}
			.blog-meta {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
			}
			.date {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: var(--accent-color);
				font-weight: 600;
			}
			.blog-tags {
				display: flex;
				gap: 0.5rem;
			}
			.mini-tag {
				font-size: 0.7rem;
				text-transform: uppercase;
				color: #78716c;
				letter-spacing: 0.05rem;
			}
			.blog-card h3 {
				margin: 0 0 1rem 0;
				font-size: 1.5rem;
				line-height: 1.3;
				color: #ffffff;
				transition: color 0.2s;
			}
			.blog-card:hover h3 {
				color: var(--accent-color);
			}
			.blog-card p {
				color: #a8a29e;
				font-size: 0.95rem;
				line-height: 1.6;
				margin: 0 0 2rem 0;
				flex-grow: 1;
			}
			.read-more {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--accent-color);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.arrow {
				transition: transform 0.2s;
			}
			.blog-card:hover .arrow {
				transform: translateX(5px);
			}

			@media (max-width: 600px) {
				.blog-list { grid-template-columns: 1fr; }
			}
		</style>
	</body>
</html>
